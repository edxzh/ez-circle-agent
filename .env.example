# ── Circle Web3 Services (https://console.circle.com) ────────────────────────
# API key for Circle Developer-Controlled Wallets (testnet key recommended)
CIRCLE_API_KEY=TEST_API_KEY:xxxxxxxxxxxxxxxxxxxxxxxx:yyyyyyyyyyyyyyyyyyyyyyyy

# 32-byte hex entity secret. Generate + register once with:
#   npm run start -- setup
CIRCLE_ENTITY_SECRET=your_64_char_hex_entity_secret

# Optional: reuse an existing wallet set / wallet. If omitted, the agent
# provisions them automatically on first run and prints the IDs so you can
# pin them here.
CIRCLE_WALLET_SET_ID=
CIRCLE_WALLET_ID=

# Testnet chain for the agent wallet. Supported examples:
#   MATIC-AMOY | ETH-SEPOLIA | ARB-SEPOLIA | BASE-SEPOLIA
CIRCLE_BLOCKCHAIN=ARB-SEPOLIA

# ── LLM (Anthropic) ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# Default model for the agent loop
ANTHROPIC_MODEL=claude-opus-4-8

# ── x402 Paid API (npm run serve) ─────────────────────────────────────────────
PORT=3000
# Address that receives the 0.002 USDC micropayments. Leave empty to use the
# agent's own Circle wallet address (auto-resolved at startup).
PAYMENT_RECEIVING_ADDRESS=
# x402 settlement network for micropayments
X402_NETWORK=base-sepolia
# Optional facilitator override (e.g. Circle's x402/Gateway facilitator).
# Empty = default public testnet facilitator (x402.org).
X402_FACILITATOR_URL=

# Demo paying client (npm run demo:client): funded testnet EOA key
CLIENT_PRIVATE_KEY=
API_URL=http://localhost:3000

# ── Test configuration ────────────────────────────────────────────────────────
# When set to "live", `npm test` performs a real 1 USDC testnet transfer to
# TEST_RECIPIENT_ADDRESS instead of using the in-memory mock wallet.
WALLET_TEST_MODE=mock
TEST_RECIPIENT_ADDRESS=0x0000000000000000000000000000000000000000
